# 複製此檔為 .env 並填入實際值（.env 不會被提交到 Git）
# cp .env.sample .env

# MySQL 資料庫連線
MYSQL_HOST=192.168.0.111
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=PJQAQC

# Anthropic Claude API 金鑰（AI 判讀功能使用），格式 sk-ant-...
ANTHROPIC_API_KEY=

# 可選：指定 AI 判讀模型（預設 claude-opus-4-8）
AI_MODEL=claude-opus-4-8
